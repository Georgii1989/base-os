# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/artifacts
/cache
/ignition/deployments

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env files with secrets — do not commit
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Explicitly track the template (not secret)
!.env.example

# other local secrets
contracts.local.env

# QA fleet (standalone scripts — private keys)
scripts/qa-fleet/wallets.json
scripts/qa-fleet/qa-fleet.local.env
scripts/qa-fleet/*.local.json
scripts/qa-fleet/wallets.backup.*.json
scripts/qa-fleet/wallets.fleet-*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local
