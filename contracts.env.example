# Copy to `contracts.local.env` (recommended). Never commit real secrets.

# Production Base OS app (HTTPS, no trailing slash in NEXT_PUBLIC_*).
NEXT_PUBLIC_APP_URL=https://app-base-os.vercel.app

BASE_RPC_URL=https://mainnet.base.org
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
TIPJAR_OWNER_ADDRESS=0xYOUR_PUBLIC_WALLET
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY
TIPJAR_ADDRESS=0x47ad142c4f04431164737cACD601796932b7357A
SBT_NAME=Base Supporter Badge
SBT_SYMBOL=BSBT
SBT_BASE_URI=https://your-metadata-host/sbt/

# Router + SBT (production defaults for deploy scripts / Vercel).
NEXT_PUBLIC_TIPJAR_ADDRESS=0xDd1090aFba3117953B892A6390B18abe5A979894
NEXT_PUBLIC_SBT_ADDRESS=0x3736b7A4fC567192AA359CaDd8407786C556F729
